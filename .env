# Firebase Google Sign-In (Web Client ID from Google Services Console)
# Required for @react-native-google-signin/google-signin
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_WEB_CLIENT_ID_HERE.apps.googleusercontent.com

# Facebook App ID (from Meta Developers Dashboard)
# Required for react-native-fbsdk-next
EXPO_PUBLIC_FACEBOOK_APP_ID=YOUR_FACEBOOK_APP_ID_HERE
EXPO_PUBLIC_FACEBOOK_CLIENT_TOKEN=YOUR_FACEBOOK_CLIENT_TOKEN_HERE

# Custom Backend API Gateway URL
# Use 10.0.2.2 for Android emulator to access computer's localhost
EXPO_PUBLIC_API_URL=http://10.32.23.105
